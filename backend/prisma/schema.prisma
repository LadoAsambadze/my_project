// Prisma schema for the Event app
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum MediaType {
  IMAGE
  VIDEO
}

model User {
  id         String    @id @default(cuid())
  email      String    @unique
  username   String?   @unique // Instagram-style handle; chosen at signup, unique. Null for legacy/OAuth accounts that haven't set one.
  firstName  String?
  lastName   String?
  birthDate  DateTime? @db.Date
  bio        String?
  avatarUrl  String?
  location   String?
  password   String? // bcrypt hash; null for accounts created via OAuth only
  googleId   String?  @unique // the Google "sub"; set when linked to a Google login
  facebookId String?  @unique // the Facebook user id; set when linked to a Facebook login
  role       Role     @default(USER)
  isVerified Boolean  @default(false) // email confirmed (OAuth signups start verified)
  isActive   Boolean  @default(true) // false = disabled; blocked from logging in
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  refreshTokens     RefreshToken[]
  emailVerification EmailVerification?
  passwordReset     PasswordReset?
  loginCode         LoginCode?

  // Follow graph: `following` = rows where this user is the follower (people
  // they follow); `followers` = rows where this user is followed.
  following Follow[] @relation("UserFollowing")
  followers Follow[] @relation("UserFollowers")

  posts Post[]
}

/// A user's post. `body` is the optional text; a post may be text-only,
/// media-only, or both. Attached images/videos live in `media`.
model Post {
  id        String      @id @default(cuid())
  authorId  String
  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String?
  media     PostMedia[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([authorId, createdAt])
}

/// A single image or video attached to a post. `url` is where the uploaded
/// file is served from; `type` drives whether it shows in the Photos or
/// Videos section.
model PostMedia {
  id        String    @id @default(cuid())
  postId    String
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  url       String
  type      MediaType
  createdAt DateTime  @default(now())

  @@index([postId])
}

/// A directed follow edge: `follower` follows `following`. One row per pair
/// (enforced by the composite unique), removed on unfollow.
model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followingId])
}

/// A pending email-verification code, created at signup. We store only the
/// bcrypt hash of the 6-digit code. At most one row per user (re-issued on
/// resend); the row is deleted once the email is verified.
model EmailVerification {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
}

/// A pending passwordless-login code, created by requestLoginCode. Confirming it
/// signs the user in (and marks the email verified). Same shape as the other
/// code tables; one row per user, deleted once consumed.
model LoginCode {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
}

/// A pending password-reset code, created by requestPasswordReset. Same shape
/// and rules as EmailVerification but a separate purpose: confirming it lets the
/// user set a new password (it does not verify the email). One row per user.
model PasswordReset {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
}

/// A hashed refresh token. We store only the hash so a DB leak can't be used
/// to mint access tokens. One row per active session/device.
model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  @@index([userId])
}
