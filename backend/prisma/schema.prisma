// Prisma schema for the Event app
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum MediaType {
  IMAGE
  VIDEO
}

/// RSVP intent on an event: firmly going, or just interested.
enum RsvpStatus {
  GOING
  INTERESTED
}

/// Thematic category a Page belongs to — the kind of event vendor it is.
/// Extend by adding values here, to the frontend PageType union + catalogs,
/// and to the `pageTypes` i18n namespace.
enum PageType {
  PHOTOGRAPHER // shows their photo/video work via posts
  DESIGNER // uploads event decor designs (weddings, birthdays, ...)
  CATERING // furshet / buffet catering for events
  FLORIST // flowers and arrangements for events
  MUSIC_SOUND // music, sound & light: performers, DJs, and sound/light rentals
}

/// Category of an Event. Each type may later carry its own extra fields; for
/// now it's just a label. Extend by adding values here, the EventType GraphQL
/// enum (event.model.ts), and the `eventTypes` i18n namespace.
enum EventType {
  PARTY
  BIRTHDAY
  SPORT
  HIKING
  CAMPING
  OTHER
}

model User {
  id         String    @id @default(cuid())
  email      String    @unique
  username   String?   @unique // Instagram-style handle; chosen at signup, unique. Null for legacy/OAuth accounts that haven't set one.
  firstName  String?
  lastName   String?
  birthDate  DateTime? @db.Date
  bio        String?
  avatarUrl  String?
  location   String?
  password   String? // bcrypt hash; null for accounts created via OAuth only
  googleId   String?  @unique // the Google "sub"; set when linked to a Google login
  facebookId String?  @unique // the Facebook user id; set when linked to a Facebook login
  role       Role     @default(USER)
  isVerified Boolean  @default(false) // email confirmed (OAuth signups start verified)
  isActive   Boolean  @default(true) // false = disabled; blocked from logging in
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  refreshTokens     RefreshToken[]
  emailVerification EmailVerification?
  passwordReset     PasswordReset?
  loginCode         LoginCode?

  // Follow graph: `following` = rows where this user is the follower (people
  // they follow); `followers` = rows where this user is followed.
  following Follow[] @relation("UserFollowing")
  followers Follow[] @relation("UserFollowers")

  posts       Post[]
  pages       Page[] // thematic pages this user owns (Facebook-style Pages)
  pageFollows PageFollow[] @relation("UserPageFollows") // pages this user follows
  events      Event[] // events this user hosts (personal, or as one of their pages)
  comments    Comment[] // comments this user wrote (on any content)
  likes       Like[] // likes this user gave (on any content)
  rsvps       EventRsvp[] // events this user is going to / interested in
  requests    Request[] // demand posts ("I need a photographer for ...")
}

/// A user-owned, thematic page (like a Facebook Page). For now it carries only
/// a name, a type, and an optional photo. A page posts just like a user does:
/// its posts live in `posts` (Post rows with this page's id in `pageId`).
model Page {
  id        String     @id @default(cuid())
  ownerId   String
  owner     User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name      String
  types       PageType[] // one or more vendor categories; always at least one (enforced in the service)
  photoUrl    String?
  phone       String? // contact phone, rendered as a tel: link
  whatsapp    String? // WhatsApp number in international format (wa.me link)
  telegram    String? // Telegram username without the @ (t.me link)
  instruments String[] // what a MUSICIAN page plays (ids from the frontend MUSIC_KINDS catalog, e.g. "SAXOPHONE")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  posts          Post[]
  followers      PageFollow[] @relation("PageFollowers")
  events         Event[] // events hosted by this page
  designs        Design[] // portfolio designs (DESIGNER pages only)
  cateringOffers CateringOffer[] // menu offers (CATERING pages only)
  offerings      Offering[] // bookable services (MUSIC_SOUND pages only)
  works          Work[] // portfolio works (PHOTOGRAPHER pages only)
  floristItems   FloristItem[] // catalog items (FLORIST pages only)

  @@index([ownerId])
}

/// A portfolio work published by a PHOTOGRAPHER ("Photo & Video") page: one
/// shoot/project with its photos and/or videos. `category` is a label from
/// the frontend catalog (e.g. "WEDDING"), mirroring Design.occasion.
model Work {
  id          String      @id @default(cuid())
  pageId      String
  page        Page        @relation(fields: [pageId], references: [id], onDelete: Cascade)
  title       String
  category    String
  description String?
  priceFrom   Int?
  media       WorkMedia[]
  comments    Comment[]
  likes       Like[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([pageId, createdAt])
  @@index([category, createdAt])
}

/// A single photo or video of a work, in upload order.
model WorkMedia {
  id        String    @id @default(cuid())
  workId    String
  work      Work      @relation(fields: [workId], references: [id], onDelete: Cascade)
  url       String
  type      MediaType
  order     Int       @default(0)
  createdAt DateTime  @default(now())

  @@index([workId])
}

/// A catalog item published by a FLORIST page: one arrangement it sells
/// (wedding bouquet, table decor, arch...). `kind` is a label from the
/// frontend catalog, mirroring Design.occasion.
model FloristItem {
  id          String             @id @default(cuid())
  pageId      String
  page        Page               @relation(fields: [pageId], references: [id], onDelete: Cascade)
  title       String
  kind        String
  description String?
  priceFrom   Int?
  images      FloristItemImage[]
  comments    Comment[]
  likes       Like[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([pageId, createdAt])
  @@index([kind, createdAt])
}

/// A single photo of a florist catalog item, in upload order.
model FloristItemImage {
  id        String      @id @default(cuid())
  itemId    String
  item      FloristItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  url       String
  order     Int         @default(0)
  createdAt DateTime    @default(now())

  @@index([itemId])
}

/// A bookable service published by a MUSICIAN or EQUIPMENT page: a performer
/// selling an act (saxophone player, DJ set, folk ensemble) or a rental
/// listing (sound system, lighting). `kind` is a label from the frontend
/// catalog (e.g. "SAXOPHONE", "SOUND_SYSTEM"), mirroring Design.occasion.
/// `priceFrom` is an optional starting price in GEL.
model Offering {
  id          String          @id @default(cuid())
  pageId      String
  page        Page            @relation(fields: [pageId], references: [id], onDelete: Cascade)
  title       String
  kind        String
  description String?
  priceFrom   Int?
  images      OfferingImage[]
  comments    Comment[]
  likes       Like[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([pageId, createdAt])
  @@index([kind, createdAt])
}

/// A single photo of an offering, in upload order.
model OfferingImage {
  id         String   @id @default(cuid())
  offeringId String
  offering   Offering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  url        String
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([offeringId])
}

/// A menu offer published by a CATERING page: one package it sells (furshet
/// set, banquet menu, coffee break, ...). `kind` is a label from the frontend
/// catalog (e.g. "FURSHET"), mirroring Design.occasion. `pricePerPerson` is an
/// optional per-guest price in GEL — the convention catering is priced in.
model CateringOffer {
  id             String               @id @default(cuid())
  pageId         String
  page           Page                 @relation(fields: [pageId], references: [id], onDelete: Cascade)
  title          String
  kind           String
  description    String?
  pricePerPerson Int?
  images         CateringOfferImage[]
  comments       Comment[]
  likes          Like[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([pageId, createdAt])
  @@index([kind, createdAt])
}

/// A single photo of a catering offer, in upload order.
model CateringOfferImage {
  id        String        @id @default(cuid())
  offerId   String
  offer     CateringOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  url       String
  order     Int           @default(0)
  createdAt DateTime      @default(now())

  @@index([offerId])
}

/// A portfolio item uploaded by a DESIGNER page: one decor setup the page
/// offers (wedding arch, birthday backdrop, ...). `occasion` is a label from
/// the frontend catalog (e.g. "WEDDING"), mirroring how Event.subtype works.
/// `priceFrom` is an optional starting price in GEL.
model Design {
  id          String        @id @default(cuid())
  pageId      String
  page        Page          @relation(fields: [pageId], references: [id], onDelete: Cascade)
  title       String
  occasion    String
  description String?
  priceFrom   Int?
  images      DesignImage[]
  comments    Comment[]
  likes       Like[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([pageId, createdAt])
  @@index([occasion, createdAt])
}

/// A single photo of a design, in upload order (`order` is the position the
/// uploader arranged them in).
model DesignImage {
  id        String   @id @default(cuid())
  designId  String
  design    Design   @relation(fields: [designId], references: [id], onDelete: Cascade)
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([designId])
}

/// A directed follow edge from a user to a page. One row per (follower, page),
/// removed on unfollow. Mirrors the user-to-user Follow model.
model PageFollow {
  id         String   @id @default(cuid())
  followerId String
  pageId     String
  follower   User     @relation("UserPageFollows", fields: [followerId], references: [id], onDelete: Cascade)
  page       Page     @relation("PageFollowers", fields: [pageId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([followerId, pageId])
  @@index([pageId])
}

/// A post. `body` is the optional text; a post may be text-only, media-only, or
/// both. Attached images/videos live in `media`. `author` is always the user
/// who created it. When `pageId` is set the post was published *as* that page
/// (shown under the page's identity); when null it's a personal user post.
model Post {
  id        String      @id @default(cuid())
  authorId  String
  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  pageId    String?
  page      Page?       @relation(fields: [pageId], references: [id], onDelete: Cascade)
  body      String?
  media     PostMedia[]
  comments  Comment[]
  likes     Like[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([authorId, createdAt])
  @@index([pageId, createdAt])
}

/// A single image or video attached to a post. `url` is where the uploaded
/// file is served from; `type` drives whether it shows in the Photos or
/// Videos section.
model PostMedia {
  id        String    @id @default(cuid())
  postId    String
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  url       String
  type      MediaType
  createdAt DateTime  @default(now())

  @@index([postId])
}

/// An event hosted by a user or one of their pages. Ownership mirrors Post:
/// `author` is always the creating user; `pageId` is set when the event is
/// hosted *as* that page (the author must own it), and null for a personal
/// event. `startsAt` is when the event takes place. RSVP/attendance is
/// intentionally not modeled yet.
model Event {
  id          String   @id @default(cuid())
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  pageId      String?
  page        Page?     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  title       String
  type        EventType @default(OTHER)
  subtype     String? // second-level category within `type` (e.g. "TENNIS" for SPORT); catalog lives in the frontend
  description String?
  location    String?
  coverUrl    String?
  startsAt    DateTime
  comments    Comment[]
  likes       Like[]
  rsvps       EventRsvp[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([authorId, startsAt])
  @@index([pageId, startsAt])
}

/// A user's RSVP on an event — going or interested. One row per (user, event);
/// switching intent updates the row, withdrawing deletes it.
model EventRsvp {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId   String
  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  status    RsvpStatus
  createdAt DateTime   @default(now())

  @@unique([userId, eventId])
  @@index([eventId, status])
}

/// A comment written by a user on any content — exactly one target id is set
/// (enforced in the service). On vendor content comments double as public
/// questions/offers ("does the price include setup?"); on requests they are
/// the vendors' replies.
model Comment {
  id              String         @id @default(cuid())
  authorId        String
  author          User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  postId          String?
  post            Post?          @relation(fields: [postId], references: [id], onDelete: Cascade)
  designId        String?
  design          Design?        @relation(fields: [designId], references: [id], onDelete: Cascade)
  eventId         String?
  event           Event?         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  cateringOfferId String?
  cateringOffer   CateringOffer? @relation(fields: [cateringOfferId], references: [id], onDelete: Cascade)
  offeringId      String?
  offering        Offering?      @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  workId          String?
  work            Work?          @relation(fields: [workId], references: [id], onDelete: Cascade)
  floristItemId   String?
  floristItem     FloristItem?   @relation(fields: [floristItemId], references: [id], onDelete: Cascade)
  requestId       String?
  request         Request?       @relation(fields: [requestId], references: [id], onDelete: Cascade)
  body            String
  createdAt       DateTime       @default(now())

  @@index([postId, createdAt])
  @@index([designId, createdAt])
  @@index([eventId, createdAt])
  @@index([cateringOfferId, createdAt])
  @@index([offeringId, createdAt])
  @@index([workId, createdAt])
  @@index([floristItemId, createdAt])
  @@index([requestId, createdAt])
}

/// A like from a user on any content — exactly one target id is set (enforced
/// in the service). One like per (user, target), removed on unlike.
model Like {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId          String?
  post            Post?          @relation(fields: [postId], references: [id], onDelete: Cascade)
  designId        String?
  design          Design?        @relation(fields: [designId], references: [id], onDelete: Cascade)
  eventId         String?
  event           Event?         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  cateringOfferId String?
  cateringOffer   CateringOffer? @relation(fields: [cateringOfferId], references: [id], onDelete: Cascade)
  offeringId      String?
  offering        Offering?      @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  workId          String?
  work            Work?          @relation(fields: [workId], references: [id], onDelete: Cascade)
  floristItemId   String?
  floristItem     FloristItem?   @relation(fields: [floristItemId], references: [id], onDelete: Cascade)
  requestId       String?
  request         Request?       @relation(fields: [requestId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())

  @@unique([userId, postId])
  @@unique([userId, designId])
  @@unique([userId, eventId])
  @@unique([userId, cateringOfferId])
  @@unique([userId, offeringId])
  @@unique([userId, workId])
  @@unique([userId, floristItemId])
  @@unique([userId, requestId])
  @@index([postId])
  @@index([designId])
  @@index([eventId])
  @@index([cateringOfferId])
  @@index([offeringId])
  @@index([workId])
  @@index([floristItemId])
  @@index([requestId])
}

/// A demand post: a user describes what they need for their event ("looking
/// for a photographer, Sept 14, Tbilisi, budget 800₾") and vendor pages of
/// the matching category discover it and reply in the comments. `category`
/// targets a vendor type; the occasion label comes from the frontend catalog.
model Request {
  id         String    @id @default(cuid())
  authorId   String
  author     User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category   PageType
  occasion   String?
  eventDate  DateTime?
  city       String?
  budgetFrom Int?
  budgetTo   Int?
  body       String
  comments   Comment[]
  likes      Like[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([category, createdAt])
  @@index([authorId, createdAt])
  @@index([createdAt])
}

/// A directed follow edge: `follower` follows `following`. One row per pair
/// (enforced by the composite unique), removed on unfollow.
model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followingId])
}

/// A pending email-verification code, created at signup. We store only the
/// bcrypt hash of the 6-digit code. At most one row per user (re-issued on
/// resend); the row is deleted once the email is verified.
model EmailVerification {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
}

/// A pending passwordless-login code, created by requestLoginCode. Confirming it
/// signs the user in (and marks the email verified). Same shape as the other
/// code tables; one row per user, deleted once consumed.
model LoginCode {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
}

/// A pending password-reset code, created by requestPasswordReset. Same shape
/// and rules as EmailVerification but a separate purpose: confirming it lets the
/// user set a new password (it does not verify the email). One row per user.
model PasswordReset {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
}

/// A hashed refresh token. We store only the hash so a DB leak can't be used
/// to mint access tokens. One row per active session/device.
model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  @@index([userId])
}
