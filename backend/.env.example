# --- Database (PostgreSQL via Docker, see docker-compose.yml) ---
DATABASE_URL="postgresql://event:event@localhost:5433/event?schema=public"

# --- Auth / JWT ---
JWT_ACCESS_SECRET="change-me"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-too"
JWT_REFRESH_EXPIRES_IN="7d"

# --- Server ---
PORT=4000
CORS_ORIGIN="http://localhost:3001"
NODE_ENV="development"
# Where the OAuth callbacks redirect the browser back to (the frontend origin).
# Falls back to CORS_ORIGIN, then http://localhost:3000, if unset.
FRONTEND_URL="http://localhost:3001"

# --- Social login (OAuth) ---
# Google: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match GOOGLE_CALLBACK_URL exactly.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:4000/auth/google/callback"

# Facebook: https://developers.facebook.com/apps -> Facebook Login -> Settings
# Add FACEBOOK_CALLBACK_URL to "Valid OAuth Redirect URIs".
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
FACEBOOK_CALLBACK_URL="http://localhost:4000/auth/facebook/callback"
