{
  "expo": {
    "name": "Event",
    "slug": "event-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "event",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.event.mobile"
    },
    "android": {
      "package": "com.event.mobile"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
