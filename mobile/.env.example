# GraphQL endpoint the app talks to.
#
# - iOS simulator / web: http://localhost:4000/graphql works.
# - Android emulator: use http://10.0.2.2:4000/graphql (localhost is the emulator itself).
# - Physical device: use your machine's LAN IP, e.g. http://192.168.1.20:4000/graphql
EXPO_PUBLIC_GRAPHQL_URL="http://localhost:4000/graphql"
